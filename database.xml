    <konten_bab id="1">
        <pengantar>
            <judul>Sunny 店内スタッフ募集</judul>
            <deskripsi>さいわい駅前店オープンにつき、人材を求めています</deskripsi>
            <posisi>Staff Toko Part-time</posisi>
            <lokasi>Saiwai Ekimae Store</lokasi>
        </pengantar>

        <grammar_list>
            <grammar id="nitsuki">
                <pattern>Ｎ＋につき</pattern>
                <arti>"Dikarenakan/Disebabkan oleh" - menyatakan alasan dalam pengumuman</arti>
                <contoh>
                    <kalimat>清掃中につき、お足元にご注意ください。</kalimat>
                    <terjemahan>Dikarenakan sedang pembersihan, mohon hati-hati dengan langkah Anda.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>改装工事中につき、左記の仮店舗で営業いたしております。</kalimat>
                    <terjemahan>Dikarenakan sedang renovasi, kami beroperasi di tempat sementara sebelah kiri.</terjemahan>
                </contoh>
                <latihan>
                    <soal>10月20日は社員研修（　　）、・・・</soal>
                    <jawaban>d</jawaban>
                </latihan>
            </grammar>

            <grammar id="towazu">
                <pattern>Ｎ＋を問わず</pattern>
                <arti>"Tanpa memandang/Tidak peduli" - anytime, anywhere, anyone</arti>
                <contoh>
                    <kalimat>年齢・経験・国籍を問わず、やる気のある方、大歓迎！</kalimat>
                    <terjemahan>Tanpa memandang usia, pengalaman, atau kebangsaan, yang bermotivasi sangat diterima!</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>このスポーツセンターは、年齢を問わず、どなたでも利用できます。</kalimat>
                    <terjemahan>Sport center ini dapat digunakan oleh siapapun tanpa memandang usia.</terjemahan>
                </contoh>
            </grammar>

            <grammar id="kagiri">
                <pattern>Ｎ＋に限り / に限る</pattern>
                <arti>"Hanya/Dibatasi untuk" - only/just</arti>
                <contoh>
                    <kalimat>N2レベル以上の方に限り、応募可。</kalimat>
                    <terjemahan>Hanya yang memiliki level N2 ke atas yang dapat melamar.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>本日に限り、通常価格100グラム1,500円の牛肉を半額でご提供。</kalimat>
                    <terjemahan>Hanya hari ini, daging sapi yang biasanya 1500 yen per 100gr dijual setengah harga.</terjemahan>
                </contoh>
            </grammar>

            <grammar id="ouji">
                <pattern>Ｎ＋に応じて / に応じた＋Ｎ</pattern>
                <arti>"Sesuai dengan/Berdasarkan" - tergantung pada kondisi</arti>
                <contoh>
                    <kalimat>経験年数に応じ、時給は考慮します。</kalimat>
                    <terjemahan>Upah per jam akan disesuaikan berdasarkan tahun pengalaman.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>給料は能力や経験に応じ、決めさせていただきます。</kalimat>
                    <terjemahan>Gaji akan ditentukan sesuai dengan kemampuan dan pengalaman.</terjemahan>
                </contoh>
            </grammar>

            <grammar id="kawarazu">
                <pattern>Ｎ＋にかかわらず</pattern>
                <arti>"Tidak tergantung pada/Tanpa memandang" - regardless of</arti>
                <contoh>
                    <kalimat>書類審査の結果は採否にかかわらず、通知します。</kalimat>
                    <terjemahan>Hasil seleksi dokumen akan diberitahukan terlepas dari diterima atau tidak.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>晴雨にかかわらず、実施します。</kalimat>
                    <terjemahan>Akan dilaksanakan terlepas dari cuaca (hujan atau cerah).</terjemahan>
                </contoh>
            </grammar>

            <grammar id="oite">
                <pattern>Ｎ＋において</pattern>
                <arti>"Di/Dalam (tempat, waktu, bidang)" - in/at</arti>
                <contoh>
                    <kalimat>当店において面接。</kalimat>
                    <terjemahan>Wawancara diadakan di toko kami.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>入学式は、3階のホールにおいて行われます。</kalimat>
                    <terjemahan>Upacara pembukaan akan diadakan di hall lantai 3.</terjemahan>
                </contoh>
            </grammar>

            <grammar id="sai">
                <pattern>Ｖる/Ｖた/Ｎの＋際（に）</pattern>
                <arti>"Pada saat/Ketika" - if/when (formal)</arti>
                <contoh>
                    <kalimat>面接の際に、履歴書（写真付き）持参のこと。</kalimat>
                    <terjemahan>Pada saat wawancara, wajib membawa riwayat hidup (dengan foto).</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>カードを紛失した際はサービスセンターにご連絡ください。</kalimat>
                    <terjemahan>Jika kartu hilang, silakan hubungi service center.</terjemahan>
                </contoh>
            </grammar>

            <grammar id="koto">
                <pattern>Ｖる/Ｖない/Ｎの＋こと</pattern>
                <arti>Menjelaskan aturan atau peringatan formal</arti>
                <contoh>
                    <kalimat>願書は1月28日必着のこと。</kalimat>
                    <terjemahan>Formulir pendaftaran harus sampai paling lambat 28 Januari.</terjemahan>
                </contoh>
                <contoh>
                    <kalimat>試験中は携帯電話の電源を切ること。</kalimat>
                    <terjemahan>Selama ujian, harus mematikan telepon genggam.</terjemahan>
                </contoh>
            </grammar>
        </grammar_list>

        <latihan_review>
